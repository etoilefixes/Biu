generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  biuId        String   @unique @db.VarChar(20)
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  nickname     String   @db.VarChar(100)
  avatar       String?  @db.VarChar(500)
  status       String   @default("offline") @db.VarChar(20)
  isSystem       Boolean  @default(false) @map("is_system")
  role           String   @default("user") @db.VarChar(20)
  officialStatus String   @default("none") @map("official_status") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  conversations ConversationMember[]
  messages      Message[]
  conversationReads ConversationRead[]
  sentFriendRequests     FriendRequest[] @relation("SentRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedRequests")
  badges        UserBadge[]
  aiRoles       AiRole[]
  aiRoleConfigs AiRoleUserConfig[]
  notificationSettings NotificationSetting[]

  @@map("users")
}

model Conversation {
  id          String   @id @default(uuid())
  biuId       String   @unique @map("biu_id") @db.VarChar(20)
  type        String   @db.VarChar(20)
  name        String?  @db.VarChar(100)
  creatorId   String   @map("creator_id")
  ownerId     String   @map("owner_id")
  announcement String? @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  members  ConversationMember[]
  messages Message[]
  conversationReads ConversationRead[]

  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  nickname       String?  @db.VarChar(100)
  role           String   @default("member") @db.VarChar(20)
  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  type           String   @default("text") @db.VarChar(20)
  cardType       String?  @map("card_type") @db.VarChar(30)
  cardData       String?  @map("card_data") @db.Text
  mentions       String?  @map("mentions") @db.Text
  mentionsAll    Boolean  @default(false) @map("mentions_all")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model ConversationRead {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  lastReadAt     DateTime @default(now()) @map("last_read_at")
  mentioned      Boolean  @default(false) @map("mentioned")
  mentionedAll   Boolean  @default(false) @map("mentioned_all")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_reads")
}

model Badge {
  id          String  @id @default(uuid())
  type        String  @db.VarChar(20)
  label       String  @db.VarChar(50)
  icon        String? @db.VarChar(50)
  color       String? @db.VarChar(20)
  description String? @db.VarChar(200)

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model FriendRequest {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  status     String   @default("pending") @db.VarChar(20)
  message    String?  @db.VarChar(200)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  fromUser User @relation("SentRequests", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedRequests", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@map("friend_requests")
}

model AiRole {
  id              String   @id @default(uuid())
  name            String   @db.VarChar(50)
  avatar          String?  @db.VarChar(500)
  description     String?  @db.VarChar(500)
  systemPrompt    String?  @map("system_prompt") @db.Text
  speakingStyle   String?  @map("speaking_style") @db.Text
  forbiddenTopics String?  @map("forbidden_topics") @db.Text
  greeting        String?  @db.VarChar(500)
  model           String?  @db.VarChar(100)
  useReasoning    Boolean  @default(false) @map("use_reasoning")
  replyLength     String   @default("medium") @map("reply_length") @db.VarChar(20)
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(2000) @map("max_tokens")
  userId          String   @map("user_id")
  visibility      String   @default("public") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  creator     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userConfigs AiRoleUserConfig[]

  @@map("ai_roles")
}

model AiRoleUserConfig {
  id           String  @id @default(uuid())
  roleId       String  @map("role_id")
  userId       String  @map("user_id")
  model        String? @db.VarChar(100)
  useReasoning Boolean @default(false) @map("use_reasoning")
  replyLength  String  @default("medium") @map("reply_length") @db.VarChar(20)
  temperature  Float   @default(0.7)
  maxTokens    Int     @default(2000) @map("max_tokens")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role AiRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roleId, userId])
  @@map("ai_role_user_configs")
}

model AiModel {
  id              String   @id @default(uuid())
  name            String   @db.VarChar(100)
  provider        String   @db.VarChar(50)
  baseUrl         String   @map("base_url") @db.VarChar(500)
  apiKeyEncrypted String?  @map("api_key_encrypted") @db.VarChar(500)
  modelName       String   @map("model_name") @db.VarChar(100)
  maxTokens       Int      @default(2000) @map("max_tokens")
  temperature     Float    @default(0.7)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  chatConfigs        AiModelConfig[] @relation("ChatModel")
  reasoningConfigs   AiModelConfig[] @relation("ReasoningModel")
  arbitrationConfigs AiModelConfig[] @relation("ArbitrationModel")

  @@map("ai_models")
}

model AiModelConfig {
  id                    String   @id @default(uuid())

  // 模型引用（新）
  chatModelId           String?  @map("chat_model_id")
  reasoningModelId      String?  @map("reasoning_model_id")
  arbitrationModelId    String?  @map("arbitration_model_id")

  chatModelRef          AiModel? @relation("ChatModel", fields: [chatModelId], references: [id])
  reasoningModelRef     AiModel? @relation("ReasoningModel", fields: [reasoningModelId], references: [id])
  arbitrationModelRef   AiModel? @relation("ArbitrationModel", fields: [arbitrationModelId], references: [id])

  // 行为配置
  reasoningEnabled      Boolean  @default(false) @map("reasoning_enabled")
  reasoningMode         String   @default("none") @map("reasoning_mode") @db.VarChar(20)
  reasoningDisplay      String   @default("hidden") @map("reasoning_display") @db.VarChar(20)
  reasoningEffort       String   @default("high") @map("reasoning_effort") @db.VarChar(20)
  streamingEnabled      Boolean  @default(true) @map("streaming_enabled")
  contextMessageLimit   Int      @default(20) @map("context_message_limit")
  arbitrationMaxTokens  Int      @default(200) @map("arbitration_max_tokens")
  includePrivateContext Boolean  @default(false) @map("include_private_context")
  aiTriggerMode         String   @default("always") @map("ai_trigger_mode") @db.VarChar(20)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("ai_model_configs")
}

model NotificationSetting {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  conversationId String   @default("") @map("conversation_id") @db.VarChar(36)
  muted          Boolean  @default(false)
  showPreview    Boolean  @default(true) @map("show_preview")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@map("notification_settings")
}
