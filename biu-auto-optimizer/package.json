    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "execa": "^9.4.0",
    "express": "^4.21.0",
    "fast-glob": "^3.3.0",
    "handlebars": "^4.7.8",
    "marked": "^14.1.0",
    "node-cron": "^3.0.3",
    "ora": "^8.1.0",
    "semver": "^7.6.0",
    "simple-git": "^3.25.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
