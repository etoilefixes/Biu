{
  "name": "biu-auto-optimizer",
  "version": "1.0.0",
  "description": "Biu 项目自迭代自动化优化工具 — lint, security audit, dependency management, and auto-optimization for monorepo",
  "private": true,
  "type": "module",
  "bin": {
    "biu-opt": "./bin/biu-opt"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
