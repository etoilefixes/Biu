{
  "name": "@biu/client",
  "version": "1.0.0",
  "main": "main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:dev:1": "concurrently \"vite\" \"wait-on http://localhost:5173 && tsc -p tsconfig.electron.json && cross-env ELECTRON_DEV=1 electron . --user-data-dir=./tmp/user-data-1\"",
    "electron:dev:2": "cross-env ELECTRON_DEV=1 electron . --user-data-dir=./tmp/user-data-2",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@biu/shared": "*",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "axios": "^1.7.0",
    "emoji-mart": "^5.6.0",
    "framer-motion": "^12.40.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  }
}
